---
import SectionHeading from "./ui/SectionHeading.astro";
import Image from "./ui/Image.astro";
import { getServiceImage } from "../config/images";
import type { Locale } from "../i18n";
import { getPageContent } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { services, images } = getPageContent(locale);
---

<section id="services" class="section-pad border-b border-border bg-surface">
  <div class="container-page">
    <SectionHeading title={services.title} subtitle={services.subtitle} />

    <div class="grid gap-6 lg:grid-cols-3 lg:gap-8">
      {
        services.items.map((service, index) => {
          const image = getServiceImage(service.id);
          const imageAlt = images.services[service.id]?.alt ?? image?.alt;

          return (
            <article
              class:list={[
                "relative flex flex-col overflow-hidden rounded-2xl border transition-shadow duration-200",
                service.featured
                  ? "border-accent/35 bg-background shadow-[var(--shadow-card-hover)] ring-1 ring-accent/25 xl:-translate-y-0.5"
                  : "card-base card-hover bg-background",
              ]}
            >
              {service.featured && service.badge && (
                <span class="absolute top-4 left-4 z-10 rounded-full bg-accent px-3 py-0.5 text-xs font-semibold text-white">
                  {service.badge}
                </span>
              )}

              {image && (
                <Image
                  src={image.src}
                  alt={imageAlt}
                  width={800}
                  height={450}
                  class="aspect-[16/9] w-full object-cover"
                />
              )}

              <div class="flex flex-1 flex-col p-6 md:p-7">
                <div class="mb-4 flex items-start gap-3">
                  <span
                    class:list={[
                      "flex h-10 w-10 shrink-0 items-center justify-center rounded-full font-serif text-lg font-semibold",
                      service.featured
                        ? "bg-accent text-white"
                        : "bg-accent/12 text-accent",
                    ]}
                    aria-hidden="true"
                  >
                    {index + 1}
                  </span>
                  <div>
                    <h3 class="font-serif text-xl font-semibold text-text">
                      {service.title}
                    </h3>
                    {service.subtitle && (
                      <p class="mt-0.5 text-sm italic text-text-muted">
                        {service.subtitle}
                      </p>
                    )}
                  </div>
                </div>

                {service.format && (
                  <p class="mb-4 text-sm font-medium text-text-muted">
                    {service.format}
                  </p>
                )}

                <ul class="mb-5 flex-1 space-y-2">
                  {service.bullets.map((bullet) => (
                    <li class="flex gap-2 text-sm leading-relaxed text-text md:text-base">
                      <span class="text-accent" aria-hidden="true">
                        ✓
                      </span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>

                <p class="mt-auto border-t border-border pt-4 text-sm text-text-muted">
                  <span class="font-medium text-text">{services.suitableLabel}</span>
                  {service.suitable}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

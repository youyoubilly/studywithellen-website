---
interface Props {
  title: string;
  subtitle?: string;
  titleEn?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  title,
  subtitle,
  titleEn,
  align = "left",
  class: className = "",
} = Astro.props;

const alignClass = align === "center" ? "text-center mx-auto" : "";
---

<div class:list={["mb-10 md:mb-12", alignClass, className]}>
  <div
    class:list={[
      "mb-4 h-1 w-10 rounded-full bg-accent",
      align === "center" && "mx-auto",
    ]}
    aria-hidden="true"
  >
  </div>
  <h2 class="font-serif text-2xl text-text md:text-3xl lg:text-[2rem]">
    {title}
  </h2>
  {
    titleEn && (
      <p class="mt-2 hidden font-serif text-sm italic text-text-muted sm:block md:text-base">
        {titleEn}
      </p>
    )
  }
  {
    subtitle && (
      <p
        class:list={[
          "mt-3 max-w-2xl text-base leading-relaxed text-text-muted md:text-lg",
          align === "center" && "mx-auto",
        ]}
      >
        {subtitle}
      </p>
    )
  }
</div>

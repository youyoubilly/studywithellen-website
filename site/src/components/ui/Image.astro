---
interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  class: className = "",
  width,
  height,
  loading = "lazy",
  fetchpriority,
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  decoding="async"
  fetchpriority={fetchpriority}
  class:list={["block max-w-full", className]}
/>

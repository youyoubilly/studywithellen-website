---
import SectionHeading from "./ui/SectionHeading.astro";
import { IMAGES } from "../config/images";
import type { Locale } from "../i18n";
import { getPageContent } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { whyEllen } = getPageContent(locale);
---

<section id="why" class="section-pad relative overflow-hidden border-b border-primary/10 bg-background">
  <div
    class="pointer-events-none absolute inset-0 bg-cover bg-center opacity-[0.07]"
    style={`background-image: url('${IMAGES.why.ambient}')`}
    aria-hidden="true"
  >
  </div>

  <div class="container-page relative">
    <SectionHeading title={whyEllen.title} />

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
      {
        whyEllen.points.map((point) => (
          <article class="card-base card-hover bg-background/95 p-5 backdrop-blur-[2px] md:p-6">
            <h3 class="font-serif text-base font-semibold text-primary md:text-lg">
              {point.title}
            </h3>
            <p class="mt-2.5 text-sm leading-relaxed text-text-muted md:text-base">
              {point.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

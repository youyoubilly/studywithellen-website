---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "./Hero.astro";
import Audience from "./Audience.astro";
import Services from "./Services.astro";
import WhyEllen from "./WhyEllen.astro";
import Background from "./Background.astro";
import Employers from "./Employers.astro";
import FAQ from "./FAQ.astro";
import Consultation from "./Consultation.astro";
import Contact from "./Contact.astro";
import type { Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<BaseLayout locale={locale}>
  <Hero locale={locale} />
  <Audience locale={locale} />
  <Services locale={locale} />
  <WhyEllen locale={locale} />
  <Background locale={locale} />
  <Employers locale={locale} />
  <FAQ locale={locale} />
  <Consultation locale={locale} />
  <Contact locale={locale} />
</BaseLayout>

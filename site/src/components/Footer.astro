---
import { CONTACT, SITE_NAME } from "../config/site";
import type { Locale } from "../i18n";
import { getPageContent } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { footer } = getPageContent(locale);
const year = new Date().getFullYear();
---

<footer class="border-t border-primary/10 bg-primary text-white">
  <div class="container-page py-10 md:py-12">
    <div
      class="flex flex-col items-center gap-4 text-center md:flex-row md:justify-between md:text-left"
    >
      <div>
        <p class="font-serif text-lg font-semibold">{SITE_NAME}</p>
        <p class="mt-1 text-sm text-white/75">
          {CONTACT.location}
          <span class="hidden sm:inline"> · </span>
          <span class="block break-all sm:inline">{CONTACT.email}</span>
        </p>
      </div>
      <p class="text-sm text-white/60">
        © {year} {footer.copyright}
      </p>
    </div>
  </div>
</footer>

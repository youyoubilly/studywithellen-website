---
import "../styles/global.css";
import { IMAGES } from "../config/images";
import { SITE_NAME } from "../config/site";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileStickyBar from "../components/MobileStickyBar.astro";
import type { Locale } from "../i18n";
import {
  getCanonicalUrl,
  getHreflangAlternates,
  getPageContent,
} from "../i18n";
import {
  buildStructuredData,
  getOgImageUrl,
  getOgLocaleAlternate,
  getThemeColor,
} from "../lib/seo";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale } = Astro.props;
const seo = getPageContent(locale).seo;
const { title = seo.title, description = seo.description } = Astro.props;
const canonical = getCanonicalUrl(locale);
const alternates = getHreflangAlternates();
const ogImage = getOgImageUrl();
const ogLocaleAlternate = getOgLocaleAlternate(locale);
const structuredData = JSON.stringify(buildStructuredData(locale));
---

<!doctype html>
<html lang={seo.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={seo.keywords.join(", ")} />
    <meta name="author" content="Ellen Wang" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="theme-color" content={getThemeColor()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={seo.ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={seo.ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.ogTitle} />
    <meta name="twitter:description" content={seo.ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={seo.ogImageAlt} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={structuredData} />
  </head>
  <body class="flex min-h-screen flex-col antialiased">
    <Header locale={locale} />
    <main class="flex-1 pb-24 md:pb-0">
      <slot />
    </main>
    <MobileStickyBar locale={locale} />
    <Footer locale={locale} />
  </body>
</html>

{
  "name": "ellen-english-studio",
  "type": "module",
  "version": "1.7.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "assets:sync": "bash ../scripts/sync-ellen-assets.sh",
    "dev": "astro dev",
    "build": "npm run assets:sync && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "npm run assets:sync && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "playwright test e2e/visual-polish.spec.ts --project=mobile --project=desktop",
    "test:qa": "playwright test e2e/qa-hardening.spec.ts",
    "verify:nginx": "bash ../scripts/verify-nginx-security.sh",
    "smoke:prod": "bash ../scripts/smoke-prod.sh",
    "verify:delivery": "bash ../scripts/verify-delivery.sh",
    "qa": "npm test && npm run check && npm run build && npm run verify:nginx && npm run test:e2e && npm audit --audit-level=high",
    "lighthouse": "npm run build && npm run preview -- --host 127.0.0.1 --port 4321 & sleep 3 && npx lighthouse http://127.0.0.1:4321 --only-categories=performance,accessibility,best-practices --form-factor=mobile --quiet --chrome-flags='--headless' && kill %1",
    "astro": "astro"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.5",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
